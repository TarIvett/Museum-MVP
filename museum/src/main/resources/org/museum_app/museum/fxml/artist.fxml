<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox stylesheets="@../css/styles.css"
      fx:controller="org.museum_app.museum.view.ArtistGUI"
      maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="640.0" prefWidth="360.0"
      xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <HBox prefHeight="50.0" prefWidth="360.0" alignment="CENTER_LEFT">
         <children>
            <Button onAction="#onBack" text="← Back" styleClass="button" style="-fx-font-size: 12px; -fx-text-fill: #8A857D; -fx-background-color: transparent;"/>
         </children>
         <padding>
            <Insets left="20.0" right="20.0" top="20.0" bottom="10.0"/>
         </padding>
      </HBox>

      <VBox alignment="CENTER" prefHeight="230.0" prefWidth="360.0">
         <children>
            <StackPane>
               <children>
                  <VBox alignment="CENTER" maxHeight="200.0" maxWidth="200.0" styleClass="image-card" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <children>
                        <ImageView fx:id="imgArtist" fitHeight="190.0" fitWidth="190.0" pickOnBounds="true" preserveRatio="true">
                           <clip>
                              <javafx.scene.shape.Rectangle arcHeight="40.0" arcWidth="40.0" height="190.0" width="190.0" />
                           </clip>
                        </ImageView>
                     </children>
                  </VBox>
               </children>
            </StackPane>
         </children>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </VBox>

      <VBox styleClass="form-card" VBox.vgrow="ALWAYS" spacing="15.0">
         <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="25.0" />
         </padding>
         <children>

            <Label fx:id="lblArtistName" text="Artist Name" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 26px; -fx-text-fill: #1A202C; -fx-font-weight: bold;" />

            <VBox spacing="8.0">
               <children>
                  <Label fx:id="lblBirthDate" text="Birth Date" />
                  <Label fx:id="lblBirthPlace" text="Birth Place" />
                  <Label fx:id="lblNationality" text="Nationality" />
               </children>
            </VBox>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
               <children>
                  <Label text="Artworks" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 18px; -fx-text-fill: #1A202C; -fx-font-weight: bold;" />

                  <ScrollPane hbarPolicy="NEVER" vbarPolicy="ALWAYS" styleClass="scroll-pane" fitToWidth="true" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="vBoxArtworks" spacing="10.0">
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</VBox>