<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="org.museum_app.museum.view.ArtworksAllGUI" stylesheets="@../css/styles.css" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="640.0" prefWidth="360.0" spacing="15.0" style="-fx-background-color: #1C1B1A;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="10.0" left="0.0" right="0.0" top="20.0" />
   </padding>
   <children>

      <VBox spacing="10.0">
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
         <children>
            <Button onAction="#onBack" text="← Back" styleClass="button" style="-fx-font-size: 12px; -fx-text-fill: #8A857D; -fx-background-color: transparent;"/>

            <HBox alignment="CENTER_LEFT" spacing="8.0">
               <children>
                  <Label styleClass="page-title" text="Artworks" />
                  <Region HBox.hgrow="ALWAYS" />

                  <Button onAction="#onAdd" styleClass="primary-button" text="＋" />
                  <Button onAction="#onEdit" styleClass="button" text="✎" textFill="#F0EBE1" style="-fx-border-color: #555555;"/>
                  <Button onAction="#onDelete" styleClass="button" text="🗑" textFill="#F0EBE1" style="-fx-border-color: #555555;"/>
               </children>
            </HBox>

            <TextField fx:id="tfSearch" promptText="Search artwork by title..." />

            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <ComboBox fx:id="cbArtist" prefWidth="155.0" promptText="Filter Artist" />
                  <ComboBox fx:id="cbGenre" prefWidth="155.0" promptText="Filter Genre" />
               </children>
            </HBox>
         </children>
      </VBox>

      <ScrollPane hbarPolicy="NEVER" styleClass="scroll-pane" vbarPolicy="ALWAYS" fitToWidth="true" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="vboxArtworkList" spacing="15.0">
               <padding>
                  <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>