<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox stylesheets="@../css/styles.css" fx:controller="org.museum_app.museum.view.ArtistFormGUI" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="640.0" prefWidth="360.0" spacing="15.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="320.0">
            <children>
                <Button onAction="#onCancel" styleClass="button" text="Cancel" textFill="#F0EBE1" style="-fx-border-color: #555555;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblPageTitle" styleClass="page-title" text="Artist Details" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#onSave" styleClass="primary-button" text="Save" />
            </children>
        </HBox>

        <ScrollPane hbarPolicy="NEVER" prefHeight="550.0" prefWidth="320.0" styleClass="scroll-pane" vbarPolicy="ALWAYS">
            <content>
                <VBox prefWidth="300.0" spacing="15.0" styleClass="form-card">
                    <padding>
                        <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
                    </padding>
                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="130.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-color: #cccccc; -fx-border-radius: 20;">
                                    <children>
                                        <ImageView fx:id="imgPreview" fitHeight="110.0" fitWidth="110.0" pickOnBounds="true" preserveRatio="true" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" alignment="CENTER">
                                    <children>
                                        <TextField fx:id="tfPhoto" HBox.hgrow="ALWAYS" promptText="Select an image..." />
                                        <Button onAction="#onBrowseImage" styleClass="primary-button" text="Browse files" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <Label text="Artist Name" />
                        <TextField fx:id="tfName" promptText="E.g., Vincent van Gogh" />

                        <Label text="Birth Year" />
                        <TextField fx:id="tfBirthDate" promptText="E.g., 1853" />

                        <Label text="Birth Place" />
                        <TextField fx:id="tfBirthPlace" promptText="E.g., Zundert, Netherlands" />

                        <Label text="Nationality" />
                        <TextField fx:id="tfNationality" promptText="E.g., Dutch" />

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>