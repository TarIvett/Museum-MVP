<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox stylesheets="@../css/styles.css"
         fx:controller="org.museum_app.museum.view.ArtistsAllGUI"
         maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
         prefHeight="640.0" prefWidth="360.0"
         spacing="25"
         xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>

      <Button onAction="#onBack" text="← Back" styleClass="button" style="-fx-font-size: 12px; -fx-text-fill: #8A857D; -fx-background-color: transparent;"/>

      <HBox alignment="CENTER_LEFT" prefWidth="320.0" spacing="10.0">
         <children>
            <Label text="Artists" styleClass="page-title" />

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#onAdd" styleClass="primary-button" text="＋" />
            <Button onAction="#onEdit" styleClass="button" text="✎" textFill="#F0EBE1" style="-fx-border-color: #555555;"/>
            <Button onAction="#onDelete" styleClass="button" text="🗑" textFill="#F0EBE1" style="-fx-border-color: #555555;"/>
         </children>
      </HBox>

      <TextField fx:id="tfSearch" promptText="Search artist by name..." />

      <ScrollPane hbarPolicy="NEVER" styleClass="scroll-pane" vbarPolicy="ALWAYS" fitToWidth="true" VBox.vgrow="ALWAYS">
         <content>
            <FlowPane fx:id="flowPaneArtists" hgap="15.0" vgap="15.0" />
         </content>
      </ScrollPane>

   </children>
</VBox>